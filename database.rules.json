{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('meta/hostUid').val() === auth.uid && newData.child('meta/status').val() === 'lobby') || (data.exists() && !newData.exists() && data.child('meta/hostUid').val() === auth.uid))",
        "meta": {
          ".write": "auth != null && data.child('hostUid').val() === auth.uid",
          "hostUid": {
            ".validate": "newData.isString()"
          },
          "status": {
            ".validate": "newData.isString()"
          },
          "createdAt": {
            ".validate": "newData.isNumber()"
          },
          "dataVersion": {
            ".validate": "newData.isString()"
          },
          "announcedAt": {
            ".validate": "newData.isNumber()"
          }
        },
        "settings": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid && root.child('rooms/' + $code + '/meta/status').val() === 'lobby'",
          "competition": {
            ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid",
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 15"
          },
          "seasonLength": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 15 && (!data.exists() || newData.val() === data.val() || !root.child('rooms/' + $code + '/history').exists())"
          },
          "turnMs": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        },
        "pool": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid && (!data.exists() || root.child('rooms/' + $code + '/meta/status').val() === 'lobby')"
        },
        "members": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "kit": {
              ".validate": "newData.isString() && newData.val().length <= 12"
            },
            "kit2": {
              ".validate": "newData.isString() && newData.val().length <= 12"
            },
            "connected": {
              ".validate": "newData.isBoolean()"
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "tally": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid"
        },
        "history": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid"
        },
        "comp": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid"
        },
        "commit": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid && root.child('rooms/' + $code + '/meta/status').val() === 'competing'",
          "$uid": {
            ".write": "auth != null && (($uid === auth.uid && !data.exists()) || root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['kickerSlot','strategy'])",
            "kickerSlot": {
              ".validate": "newData.isString()"
            },
            "strategy": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
            },
            "at": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "draft": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid && (!data.child('picks').exists() || root.child('rooms/' + $code + '/meta/status').val() === 'competing')",
          "picks": {
            "$idx": {
              ".write": "auth != null && !data.exists() && $idx === (root.child('rooms/' + $code + '/draft/pickIndex').val() + '') && (root.child('rooms/' + $code + '/draft/currentPicker').val() === auth.uid || (root.child('rooms/' + $code + '/settings/turnMs').val() > 0 && now > root.child('rooms/' + $code + '/draft/turnStartedAt').val() + root.child('rooms/' + $code + '/settings/turnMs').val()))",
              ".validate": "newData.hasChildren(['by','slot','i']) && newData.child('by').val() === root.child('rooms/' + $code + '/draft/currentPicker').val()",
              "by": {
                ".validate": "newData.isString()"
              },
              "slot": {
                ".validate": "newData.isString()"
              },
              "i": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              }
            }
          },
          "pickIndex": {
            ".write": "auth != null && (root.child('rooms/' + $code + '/draft/currentPicker').val() === auth.uid || (root.child('rooms/' + $code + '/settings/turnMs').val() > 0 && now > root.child('rooms/' + $code + '/draft/turnStartedAt').val() + root.child('rooms/' + $code + '/settings/turnMs').val())) && newData.isNumber() && newData.val() === data.val() + 1"
          },
          "currentPicker": {
            ".write": "auth != null && (root.child('rooms/' + $code + '/draft/currentPicker').val() === auth.uid || (root.child('rooms/' + $code + '/settings/turnMs').val() > 0 && now > root.child('rooms/' + $code + '/draft/turnStartedAt').val() + root.child('rooms/' + $code + '/settings/turnMs').val())) && newData.isString()"
          },
          "turnStartedAt": {
            ".write": "auth != null && (root.child('rooms/' + $code + '/draft/currentPicker').val() === auth.uid || (root.child('rooms/' + $code + '/settings/turnMs').val() > 0 && now > root.child('rooms/' + $code + '/draft/turnStartedAt').val() + root.child('rooms/' + $code + '/settings/turnMs').val()))",
            ".validate": "newData.isNumber()"
          }
        },
        "boards": {
          "$uid": {
            ".read": "auth != null && ($uid === auth.uid || (root.child('rooms/' + $code + '/draft/currentPicker').val() === $uid && (root.child('rooms/' + $code + '/settings/turnMs').val() > 0 && now > root.child('rooms/' + $code + '/draft/turnStartedAt').val() + root.child('rooms/' + $code + '/settings/turnMs').val())))",
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "ready": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid",
          "$uid": {
            ".write": "auth != null && $uid === auth.uid",
            ".validate": "newData.isBoolean()"
          }
        },
        "entered": {
          ".write": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid",
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid)",
            ".validate": "newData.isBoolean()"
          }
        }
      }
    }
  }
}