{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      "$code": {
        ".read": "auth != null",

        "meta": {
          ".write": "auth != null && (!data.exists() || data.child('hostUid').val() === auth.uid)",
          "hostUid": {
            ".validate": "newData.isString() && (data.val() === newData.val() || newData.val() === auth.uid || data.parent().child('hostUid').val() === auth.uid)"
          },
          "status": { ".validate": "newData.isString()" },
          "createdAt": { ".validate": "newData.isNumber()" },
          "dataVersion": { ".validate": "newData.isString()" },
          "$other": { ".validate": false }
        },

        "settings": {
          ".write": "auth != null && newData.parent().child('meta/hostUid').val() === auth.uid && newData.parent().child('meta/status').val() === 'lobby'"
        },

        "pool": {
          ".write": "auth != null && !data.exists() && newData.parent().child('meta/hostUid').val() === auth.uid"
        },

        "members": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid",
            "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20" },
            "kit":  { ".validate": "newData.isString() && newData.val().length <= 12" },
            "connected": { ".validate": "newData.isBoolean()" },
            "joinedAt": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "draft": {
          ".write": "auth != null && root.child('rooms/'+$code+'/meta/hostUid').val() === auth.uid && !data.child('picks').exists()",
          "picks": {
            "$slot": {
              ".write": "auth != null && !data.exists() && root.child('rooms/'+$code+'/draft/currentPicker').val() === auth.uid",
              ".validate": "newData.child('by').val() === auth.uid"
            }
          }
        }
      }
    }
  }
}
